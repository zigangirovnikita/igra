{
  "name": "launch-game",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:config": "tsx scripts/validate-config.ts",
    "simulate:balance": "tsx scripts/balance-sim.ts",
    "export:sessions": "tsx scripts/export-sessions.ts",
    "db:validate": "DATABASE_URL=postgresql://launch_game:launch_game@localhost:5432/launch_game prisma validate",
    "db:migrate:test": "DATABASE_URL=postgresql://launch_game:launch_game@localhost:5432/launch_game prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm validate:config && pnpm build",
    "db:migrate:deploy": "prisma migrate deploy",
    "test:flow": "vitest run tests/unit/flow tests/unit/engine",
    "test:release": "pnpm check && pnpm db:validate && pnpm db:migrate:test && pnpm test:e2e",
    "simulate:balance:release": "tsx scripts/balance-sim.ts --runs 50000"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "globals": "^15.14.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.18.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
